44,44,0,0,0,1,0,0
45,45,0,1,0,0,0,1
46,46,0,0,0,1,0,0
47F,47,0,0,1,1,0,0
47A,47,0,0,1,1,0,0
48,48,0,1,0,0,0,0
")
# --- Step 2: Calculate the Antigenic Similarity Index ---
# An edge will exist between two serotypes if they share immunogenic features.
# The edge weight is their similarity score, calculated as a weighted dot product.
# Define weights for each antigenic feature
feature_weights <- c(has_PCho = 5, has_OAc = 2, has_Pyruvate = 3,
has_Rha = 1, has_GlcA = 1.5, has_LacNAc_backbone = 2.5)
edge_list <- list()
serotypes <- antigenic_data$Serotype
for (i in 1:(nrow(antigenic_data) - 1)) {
for (j in (i + 1):nrow(antigenic_data)) {
vec_i <- antigenic_data[i, names(feature_weights)]
vec_j <- antigenic_data[j, names(feature_weights)]
# Calculate similarity as the weighted dot product of the feature vectors
similarity_score <- sum(vec_i * vec_j * feature_weights)
# Add a bonus for being in the same serogroup (high cross-reactivity)
if (antigenic_data$Serogroup[i] == antigenic_data$Serogroup[j]) {
similarity_score <- similarity_score + 4
}
# Only create an edge if the similarity is above a certain threshold
if (similarity_score > 4) { # Threshold filters for significant relationships
edge_list[[length(edge_list) + 1]] <- c(serotypes[i], serotypes[j], similarity_score)
}
}
}
edge_df <- as.data.frame(do.call(rbind, edge_list))
names(edge_df) <- c("from", "to", "weight")
edge_df$weight <- as.numeric(edge_df$weight)
# --- Step 3: Build and Configure the Network Graph ---
g <- graph_from_data_frame(d = edge_df, vertices = antigenic_data, directed = FALSE)
# Color nodes by Serogroup for intuitive visualization
unique_serogroups <- sort(unique(V(g)$Serogroup))
num_colors <- length(unique_serogroups)
palette <- colorRampPalette(brewer.pal(9, "Set1"))(num_colors)
names(palette) <- unique_serogroups
V(g)$color <- palette[V(g)$Serogroup]
# Set visual attributes
V(g)$size <- 6
V(g)$label.cex <- 0.8
V(g)$label.color <- "black"
E(g)$width <- E(g)$weight / 5 # Scale edge width by similarity score
E(g)$color <- "gray80"
# --- Step 4: Visualize the Network with a Robust Legend ---
# Use the layout trick to prevent the legend from overlapping the graph
layout(matrix(c(1, 2), nrow = 1), widths = c(4, 1.2))
par(mar = c(1, 1, 1, 1)) # Set plot margins
# Plot the graph in the first region
set.seed(42) # for reproducibility
plot(g,
layout = layout_with_fr(g),
vertex.label = V(g)$Serotype,
main = "Pneumococcal Serotype Antigenic Similarity Network"
)
# Create a dedicated, empty plot for the legend in the second region
par(mar = c(0, 0, 0, 0))
plot.new()
# Add the legend for Serogroup colors
legend("center",
legend = names(palette),
fill = palette,
title = "Serogroup",
ncol = 2, # Arrange legend in two columns to fit better
cex = 0.9,
bty = "n"
)
# Reset the graphics device layout
layout(1)
