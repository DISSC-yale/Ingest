# Load necessary libraries
library(igraph)
library(dplyr)
library(RColorBrewer)
# --- Step 1: Curated Antigenic Feature Data ---
# This data represents a feature-based abstraction of the 92 classical pneumococcal
# capsules. A '1' indicates the presence of a key immunogenic feature. The features
# are weighted in the similarity calculation to reflect their immunological importance.
# (e.g., PCho = Phosphocholine, OAc = Acetylation, LacNAc = N-acetyllactosamine motif)
antigenic_data <- read.csv(text = "
Serotype,Serogroup,has_PCho,has_OAc,has_Pyruvate,has_Rha,has_GlcA,has_LacNAc_backbone
1,1,0,1,0,0,1,0
2,2,0,0,0,3,0,0
3,3,0,1,0,0,2,0
4,4,0,0,1,0,0,1
5,5,0,0,0,0,0,0
6A,6,1,0,0,1,0,0
6B,6,1,0,0,1,0,0
6C,6,0,0,0,1,0,0
6D,6,0,0,0,1,0,0
7F,7,0,1,0,2,0,1
7A,7,0,1,0,1,0,1
7B,7,0,1,0,2,0,1
7C,7,0,1,0,1,0,1
8,8,0,1,0,0,2,0
9N,9,0,1,0,0,2,0
9V,9,0,1,0,0,2,0
9A,9,0,1,0,0,2,0
9L,9,0,1,0,0,2,0
10A,10,0,1,0,1,0,1
10B,10,0,1,0,1,0,1
10F,10,0,0,0,0,0,2
10C,10,0,0,0,0,0,2
11A,11,1,1,0,0,0,0
11B,11,1,0,0,0,0,0
11C,11,0,1,0,0,0,0
11D,11,1,1,0,0,0,0
11F,11,1,0,0,0,0,0
12F,12,0,1,0,0,0,2
12A,12,0,1,0,0,0,2
12B,12,0,1,0,0,0,2
13,13,1,1,0,1,0,1
14,14,0,0,0,0,0,3
15A,15,0,1,0,0,0,2
15F,15,0,1,0,0,0,2
15B,15,0,0,0,0,0,1
15C,15,0,0,0,0,0,1
16F,16,0,0,0,0,0,1
16A,16,0,0,0,0,0,0
17F,17,1,0,0,1,0,0
17A,17,1,0,0,1,0,0
18C,18,0,1,0,0,0,1
18A,18,0,1,0,0,0,1
18B,18,0,1,0,0,0,1
18F,18,0,1,0,0,0,1
19F,19,1,0,0,2,0,0
19A,19,0,0,0,2,0,0
19B,19,0,0,0,2,0,0
19C,19,0,0,0,2,0,0
20,20,1,0,0,0,1,0
21,21,1,0,0,1,0,0
22F,22,0,1,1,1,0,0
22A,22,0,1,1,1,0,0
23F,23,1,0,0,2,0,1
23A,23,0,0,0,2,0,1
23B,23,0,0,0,2,0,1
24F,24,1,1,0,1,0,1
24A,24,1,1,0,1,0,1
24B,24,1,1,0,1,0,1
25F,25,0,0,1,0,0,0
25A,25,0,0,1,0,0,0
27,27,0,0,1,1,0,0
28F,28,0,0,1,1,0,0
28A,28,0,0,1,1,0,0
29,29,0,0,1,0,0,0
31,31,0,0,0,1,0,0
32F,32,0,1,0,2,0,0
32A,32,0,1,0,2,0,0
33F,33,0,1,0,0,0,1
33A,33,0,1,0,0,0,1
33B,33,0,1,0,0,0,1
33C,33,0,1,0,0,0,1
33D,33,0,1,0,0,0,1
34,34,0,0,0,0,0,1
35A,35,0,0,0,0,0,2
35B,35,1,0,0,0,0,0
35C,35,0,0,0,0,0,2
35F,35,0,0,0,0,0,2
36,36,0,1,0,0,0,0
37,37,0,0,0,0,0,0
38,38,0,1,0,1,0,1
