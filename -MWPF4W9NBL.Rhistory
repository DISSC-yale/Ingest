# --- Step 2: Calculate True Capsular Antigenic Similarity ---
# Weights are adjusted to reflect true immunogenicity of capsular features.
# A large bonus is given for belonging to the same serogroup.
feature_weights_corrected <- c(has_OAc = 2.5, has_Pyruvate = 3.5,
has_Rha = 1, has_GlcA = 1.5, has_LacNAc_backbone = 3)
edge_list_corrected <- list()
serotypes <- antigenic_data_corrected$Serotype
for (i in 1:(nrow(antigenic_data_corrected) - 1)) {
for (j in (i + 1):nrow(antigenic_data_corrected)) {
vec_i <- antigenic_data_corrected[i, names(feature_weights_corrected)]
vec_j <- antigenic_data_corrected[j, names(feature_weights_corrected)]
similarity_score <- sum(vec_i * vec_j * feature_weights_corrected)
# Apply a large similarity bonus for being in the same serogroup
if (antigenic_data_corrected$Serogroup[i] == antigenic_data_corrected$Serogroup[j]) {
similarity_score <- similarity_score + 8
}
# Create an edge if the similarity is significant
if (similarity_score > 5) {
edge_list_corrected[[length(edge_list_corrected) + 1]] <- c(serotypes[i], serotypes[j], similarity_score)
}
}
}
edge_df_corrected <- as.data.frame(do.call(rbind, edge_list_corrected))
names(edge_df_corrected) <- c("from", "to", "weight")
edge_df_corrected$weight <- as.numeric(edge_df_corrected$weight)
# --- Step 3: Build and Visualize the Corrected Network ---
g_corrected <- graph_from_data_frame(d = edge_df_corrected, vertices = antigenic_data_corrected, directed = FALSE)
# Color nodes by Serogroup
unique_serogroups <- sort(unique(V(g_corrected)$Serogroup))
num_colors <- length(unique_serogroups)
palette <- colorRampPalette(brewer.pal(9, "Set1"))(num_colors)
names(palette) <- unique_serogroups
V(g_corrected)$color <- palette[V(g_corrected)$Serogroup]
# Set visual attributes
V(g_corrected)$size <- 6
V(g_corrected)$label.cex <- 0.8
E(g_corrected)$width <- E(g_corrected)$weight / 8 # Adjusted scaling
E(g_corrected)$color <- "gray80"
# Use the layout with a dedicated legend area
layout(matrix(c(1, 2), nrow = 1), widths = c(4, 1.2))
par(mar = c(1, 1, 1, 1))
# Plot the graph
set.seed(42) # for reproducibility
plot(g_corrected,
layout = layout_with_fr(g_corrected),
vertex.label = V(g_corrected)$Serotype,
main = "Corrected Pneumococcal CAPSULAR Antigenic Similarity"
)
# Create legend
par(mar = c(0, 0, 0, 0))
plot.new()
legend("center",
legend = names(palette),
fill = palette,
title = "Serogroup",
ncol = 2,
cex = 0.9,
bty = "n"
)
