{
  "geography_name": {
    "name": "geography_name",
    "description": "Name of the geographic area",
    "measure_type": "Geography",
    "unit": "text",
    "time_resolution": "N/A"
  },

  "n_deaths_all_cause": {
    "name": "n_deaths_all_cause",
    "description": "Number of deaths due to any cause over past 12 months",
    "measure_type": "Number of deaths",
    "unit": "count",
    "time_resolution": "12 months",
    "sources": ["nchs_vsrr_provisional"]
  },

  "n_deaths_overdose": {
    "name": "n_deaths_overdose",
    "description": "Number of deaths due to an overdose over past 12 months",
    "measure_type": "Number of deaths",
    "unit": "count",
    "time_resolution": "12 months",
    "sources": ["nchs_vsrr_provisional"]
  },

  "pct_drug_specified": {
    "name": "pct_drug_specified",
    "description": "Percentage of overdose deaths where drug is specified",
    "measure_type": "Percentage of deaths",
    "unit": "percent",
    "time_resolution": "12 months",
    "sources": ["nchs_vsrr_provisional"]
  },

  "pct_pending_invest": {
    "name": "pct_pending_invest",
    "description": "Percentage of deaths pending investigation",
    "measure_type": "Percentage of deaths",
    "unit": "percent",
    "time_resolution": "12 months",
    "sources": ["nchs_vsrr_provisional"]
  },

  "pct_complete": {
    "name": "pct_complete",
    "description": "Expected completeness of death records",
    "measure_type": "Percentage of deaths",
    "unit": "percent",
    "time_resolution": "12 months",
    "sources": ["nchs_vsrr_provisional"]
  },

  "_variant_templates": {
    "n_deaths_{drug}": {
      "name_template": "n_deaths_{drug}",
      "description_template": "Number of deaths due to {Drug_label.1} over past 12 months (ICD10: {icd})",
      "measure_type": "Number of deaths",
      "unit": "count",
      "time_resolution": "12 months",
      "sources": ["nchs_vsrr_provisional"],
      "variants": [
        { "drug": "cocaine", "Drug_label.1": "Cocaine", "icd": "T40.5" },
        { "drug": "heroin", "Drug_label.1": "Heroin", "icd": "T40.1" },
        { "drug": "methadone", "Drug_label.1": "Methadone", "icd": "T40.3" },
        { "drug": "any_opioid", "Drug_label.1": "any opioid", "icd": "T40.2-T40.4" }
      ]
    },

    "rate_{cause}": {
      "name_template": "rate_{cause}",
      "description_template": "Age-adjusted death rate from {Cause_label.1} per 100,000 population",
      "measure_type": "Death rate",
      "unit": "rate per 100,000",
      "time_resolution": "yearly",
      "sources": ["nvss_21_causes"],
      "variants": [
        { "cause": "all_causes", "Cause_label.1": "all causes" },
        { "cause": "alzheimer_disease", "Cause_label.1": "Alzheimer's disease" },
        { "cause": "cancer", "Cause_label.1": "cancer" },
        { "cause": "chronic_liver_disease_and_cirrhosis", "Cause_label.1": "chronic liver disease and cirrhosis" },
        { "cause": "chronic_lower_respiratory_diseases", "Cause_label.1": "chronic lower respiratory diseases" },
        { "cause": "covid_19", "Cause_label.1": "COVID-19" },
        { "cause": "diabetes", "Cause_label.1": "diabetes" },
        { "cause": "drug_overdose", "Cause_label.1": "drug overdose" },
        { "cause": "heart_disease", "Cause_label.1": "heart disease" },
        { "cause": "suicide", "Cause_label.1": "suicide" },
        { "cause": "unintentional_injuries", "Cause_label.1": "unintentional injuries" }
      ]
    }
  },

  "_sources": {
    "nchs_vsrr_provisional": {
      "organization": "Centers for Disease Control and Prevention (NCHS)",
      "organization_url": "https://www.cdc.gov/nchs/nvss/vsrr/drug-overdose-data.htm",
      "location": "VSRR Provisional Drug Overdose Death Counts",
      "location_url": "https://data.cdc.gov/National-Center-for-Health-Statistics/VSRR-Provisional-Drug-Overdose-Death-Counts/xkb8-kh2a/about_data",
      "description": "Provisional counts for drug overdose deaths from the National Vital Statistics System. Provisional counts may be incomplete and causes may be pending investigation; methods exist to adjust for reporting delays. Data updated monthly.",
      "date_accessed": 2025
    },

    "nvss_21_causes": {
      "organization": "National Center for Health Statistics (NCHS)",
      "organization_url": "https://www.cdc.gov/nchs",
      "location": "NVSS - 21 Cause of Death Groupings (state-level)",
      "description": "State-level counts grouped into the standard 21 cause categories (from NVSS)",
      "date_accessed": 2025
    }
  }
}
