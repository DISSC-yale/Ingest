  "measure_info": {
    "delphi_nhsn_covid": {
      "id": "delphi_nhsn_covid",
      "short_name": "COVID Hospitalizations (NHSN)",
      "long_name": "Number of COVID hospitalizations in the National Healthcare Safety Network",
      "category": "respiratory",
      "short_description": "Weekly count of COVID-19 associated hospital admissions reported to CDC's NHSN.",
      "long_description": "The National Healthcare Safety Network (NHSN) is the nation's most widely used healthcare-associated infection tracking system. This dataset reports preliminary and finalized weekly hospital respiratory data and metrics aggregated to national and state/territory levels. Values are available for reference dates beginning August 2020. HHS collects data from state and territorial health departments about many, but not all, hospitals in the U.S. Notably excluded from this dataset are psychiatric and rehabilitation facilities, and religious non-medical facilities.",
      "measure_type": "count",
      "unit": "hospitalizations",
      "time_resolution": "week",
      "sources": [
        {
          "id": "delphi_nhsn"
        }
      ]
    },
    "delphi_nhsn_flu": {
      "id": "delphi_nhsn_flu",
      "short_name": "Influenza Hospitalizations (NHSN)",
      "long_name": "Number of influenza hospitalizations in the National Healthcare Safety Network",
      "category": "respiratory",
      "short_description": "Weekly count of influenza-associated hospital admissions reported to CDC's NHSN.",
      "long_description": "The National Healthcare Safety Network (NHSN) is the nation's most widely used healthcare-associated infection tracking system. This dataset reports preliminary and finalized weekly hospital respiratory data and metrics aggregated to national and state/territory levels. Values are available for reference dates beginning August 2020. HHS collects data from state and territorial health departments about many, but not all, hospitals in the U.S. Notably excluded from this dataset are psychiatric and rehabilitation facilities, and religious non-medical facilities.",
      "measure_type": "count",
      "unit": "hospitalizations",
      "time_resolution": "week",
      "sources": [
        {
          "id": "delphi_nhsn"
        }
      ]
    },
    "delphi_nhsn_rsv": {
      "id": "delphi_nhsn_rsv",
      "short_name": "RSV Hospitalizations (NHSN)",
      "long_name": "Number of RSV hospitalizations in the National Healthcare Safety Network",
      "category": "respiratory",
      "short_description": "Weekly count of RSV-associated hospital admissions reported to CDC's NHSN.",
      "long_description": "The National Healthcare Safety Network (NHSN) is the nation's most widely used healthcare-associated infection tracking system. This dataset reports preliminary and finalized weekly hospital respiratory data and metrics aggregated to national and state/territory levels. Note: RSV data from the pre-October 31, 2024 voluntary reporting period has limited quality due to low hospital participation rates.",
      "measure_type": "count",
      "unit": "hospitalizations",
      "time_resolution": "week",
      "sources": [
        {
          "id": "delphi_nhsn"
        }
      ]
    },
    "_sources": {
      "delphi_nhsn": {
        "name": "CMU Delphi COVIDcast - NHSN Respiratory Hospitalizations",
        "url": "https://cmu-delphi.github.io/delphi-epidata/api/covidcast-signals/nhsn.html",
        "organization": "Carnegie Mellon University Delphi Research Group",
        "organization_url": "https://delphi.cmu.edu/",
        "location": "COVIDcast Epidata API",
        "location_url": "https://cmu-delphi.github.io/delphi-epidata/",
        "description": "Weekly hospital respiratory data reported to CDC's National Healthcare Safety Network (NHSN), accessed via the CMU Delphi Epidata API. NHSN is the nation's most widely used healthcare-associated infection tracking system, collecting data from hospitals across the United States. The data includes COVID-19, influenza, and RSV associated hospital admissions aggregated to national and state levels. Data collection became mandatory for hospitals in November 2024; prior to this, reporting was voluntary with variable participation rates.",
        "restrictions": "CC-BY Attribution license. Data may be used with attribution to the CMU Delphi Group and CDC NHSN."
      },
