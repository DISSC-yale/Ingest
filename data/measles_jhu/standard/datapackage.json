  "measure_info": {
    "value": {
      "id": "value",
      "short_name": "Measles Cases",
      "long_name": "Number of Laboratory-Confirmed Measles Cases",
      "short_description": "Count of laboratory-confirmed measles cases.",
      "measure_type": "integer",
      "unit": "cases",
      "sources": [
        {
          "id": "jhu_measles"
        }
      ]
    },
    "measles_cases_jhu": {
      "id": "measles_cases_jhu",
      "short_name": "JHU Measles Cases",
      "long_name": "Laboratory-Confirmed Measles Cases from Johns Hopkins University Measles Tracking Team",
      "category": "respiratory",
      "short_description": "Weekly laboratory-confirmed measles cases reported by state and county health departments.",
      "long_description": "This dataset contains laboratory-confirmed measles cases compiled by the Johns Hopkins University Measles Tracking Team from official state and county health department reports. The data includes weekly case counts for top reporting states (Kansas, New Mexico, Texas) based on rash onset dates when available, and daily county-level cases for all reporting jurisdictions based on official reporting dates. Data is compiled from 37 jurisdictions across the United States covering the 2025 measles outbreak. The tracking team updates data on Tuesdays and Fridays at approximately 5:00 PM Eastern Time. Case data reflects when cases were officially reported by health authorities and may be subject to revision as investigations continue.",
      "statement": "In {location}, {value} laboratory-confirmed measles cases were reported during the week ending {date}",
      "measure_type": "Count",
      "unit": "Cases",
      "time_resolution": "Week",
      "restrictions": "CC BY 4.0 - Attribution required for reuse",
      "sources": [
        {
          "name": "Johns Hopkins University Measles Tracking Team",
          "url": "https://github.com/CSSEGISandData/measles_data"
        }
      ],
      "citations": [
        {
          "title": "JHU Measles Data Repository",
          "url": "https://github.com/CSSEGISandData/measles_data"
        }
      ]
    },
    "measles_cases_state_jhu": {
      "id": "measles_cases_state_jhu",
      "short_name": "JHU State Measles Cases",
      "long_name": "State-Level Weekly Laboratory-Confirmed Measles Cases",
      "category": "respiratory",
      "short_description": "Weekly state-level laboratory-confirmed measles cases from JHU tracking team.",
      "long_description": "State-level aggregation of laboratory-confirmed measles cases from the Johns Hopkins University Measles Tracking Team. For Kansas, New Mexico, and Texas, data comes directly from the Top States Time Series dataset using rash onset dates. For other states, data is aggregated from county-level reports. This provides a comprehensive view of measles transmission across all reporting states during the 2025 outbreak.",
      "statement": "In {location}, {value} laboratory-confirmed measles cases were reported during the week ending {date}",
      "measure_type": "Count",
      "unit": "Cases",
      "time_resolution": "Week",
      "restrictions": "CC BY 4.0 - Attribution required for reuse",
      "sources": [
        {
          "name": "Johns Hopkins University Measles Tracking Team",
          "url": "https://github.com/CSSEGISandData/measles_data"
        }
      ],
      "citations": [
        {
          "title": "JHU Measles Data Repository",
          "url": "https://github.com/CSSEGISandData/measles_data"
        }
      ]
    },
    "measles_cases_county_jhu": {
      "id": "measles_cases_county_jhu",
      "short_name": "JHU County Measles Cases",
      "long_name": "County-Level Weekly Laboratory-Confirmed Measles Cases",
      "category": "respiratory",
      "short_description": "Weekly county-level laboratory-confirmed measles cases from JHU tracking team.",
      "long_description": "County-level laboratory-confirmed measles cases aggregated to weekly reporting periods following CDC epiweek conventions (weeks ending on Saturday). Data is sourced from the Johns Hopkins University Measles Tracking Team's compilation of official county health department reports. This granular geographic data enables tracking of local transmission dynamics and outbreak hotspots during the 2025 measles outbreak. Cases reflect official reporting dates and may include retrospective updates as investigations are completed.",
      "statement": "In {location}, {value} laboratory-confirmed measles cases were reported during the week ending {date}",
      "measure_type": "Count",
      "unit": "Cases",
      "time_resolution": "Week",
      "restrictions": "CC BY 4.0 - Attribution required for reuse",
      "sources": [
        {
          "id": "jhu_measles"
        }
      ],
      "citations": [
        {
          "title": "JHU Measles Data Repository",
          "url": "https://github.com/CSSEGISandData/measles_data"
        }
      ]
    },
    "_sources": {
      "jhu_measles": {
        "name": "Johns Hopkins University Measles Tracking Team",
        "url": "https://github.com/CSSEGISandData/measles_data",
        "organization": "Johns Hopkins Bloomberg School of Public Health",
        "organization_url": "https://publichealth.jhu.edu/",
        "description": "The Johns Hopkins University Measles Tracking Team compiles laboratory-confirmed measles case data from official state and county health department reports across the United States. The team aggregates data from 37+ jurisdictions, providing both state-level weekly summaries (using rash onset dates when available) and county-level daily case counts (based on official reporting dates). Data is updated on Tuesdays and Fridays at approximately 5:00 PM Eastern Time. The tracking effort was established in response to the 2025 measles outbreak to provide timely, granular geographic data on measles transmission. All data is released under CC BY 4.0 license with attribution required.",
        "restrictions": "CC BY 4.0. Attribution required for reuse. Please cite as JHU Measles Tracking Team Data Repository at Johns Hopkins University or JHU Measles Tracking Team Data for short. Copyright: Johns Hopkins University 2025"
      },
